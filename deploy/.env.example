# =============================================================================
# Yanki environment — EXAMPLE / TEMPLATE (placeholders only).
#
#   Copy to deploy/.env and fill in real values:   cp deploy/.env.example deploy/.env
#
#   *** NEVER COMMIT REAL SECRETS ***
#   deploy/.env is gitignored. Only this .env.example (placeholders) is tracked.
#   docker compose reads deploy/.env via `env_file`.
# =============================================================================

# --- Run mode ---------------------------------------------------------------
# 1 = run the whole pipeline on a deterministic MOCK provider ($0, no keys).
# 0 = call the real providers (requires the API keys below).
DRY_RUN=1

# --- LLM provider keys ------------------------------------------------------
# Leave blank when DRY_RUN=1. Required only when DRY_RUN=0.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Gemini + Perplexity (P5.7 — real 4-engine panel). Fields are staged so the
# operator can paste keys any time; the code reads them only once P5.7's
# adapters land (until then they are inert, and DRY_RUN/CI never call them).
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# --- Database ---------------------------------------------------------------
# Postgres password for the db container (used in prod; dev uses "yanki").
POSTGRES_PASSWORD=change-me-in-prod
# SQLAlchemy URL. In docker compose the api/worker get this injected for you;
# set it here only when running the backend directly on the host.
DATABASE_URL=postgresql+psycopg://yanki:yanki@localhost:5432/yanki

# --- Pipeline / cost controls -----------------------------------------------
PROMPT_COUNT=10
PANEL_ENGINES=anthropic,openai,gemini,perplexity
MAX_RESPONSES_PER_JOB=60

# --- Rate limiting (POST /api/v1/analyses) ----------------------------------
# The submit endpoint is public with real keys; these reject before any row is
# created or money is spent.
# Max submits per client IP per rolling hour (429 + Retry-After over this).
# 0 is a kill-switch: every submit is rejected 429 (no crash, no spend).
ANALYSES_RATE_LIMIT_PER_IP_HOUR=5
# Global backstop: max submits across ALL IPs per rolling 24h. 0 = kill-switch.
ANALYSES_DAILY_CAP=100
# Salt mixed into the stored ip_hash (sha256(salt+ip)); blank is fine for MVP.
IP_HASH_SALT=

# --- Checker (POST /api/v1/checker) -----------------------------------------
# A fresh checker run is reused for this many hours when a done analysis with
# the same normalized (brand, category, lang) exists, so a hot brand costs $0
# on repeat and can't be hammered into new LLM spend.
CHECKER_RESULT_CACHE_HOURS=24

# --- Checker public hardening (POST /api/v1/checker) — P5.6 ------------------
# The checker is anonymous and, with real keys, LLM-spending. These guards run
# BEFORE enqueuing; a $0 24h cache hit is exempt from all of them (it must still
# return its id so the email gate can attach a lead). The stored ip_hash reuses
# IP_HASH_SALT above — there is no separate checker salt.
#
# Master kill-switch. 0 = OFF (default): a FRESH submit is parked with a friendly
# 503 and records nothing; a 24h cached-brand hit still returns (it costs $0).
# The operator flips this to 1 at P5.11 go-live — the public surface stays dark
# in every environment until then.
CHECKER_ENABLED=0
# Max checker submissions per client IP per rolling hour (429 + Retry-After over
# this). 0 = kill-switch (rejects every fresh submit), same idiom as the
# analyses caps above.
CHECKER_RATE_LIMIT_PER_IP_HOUR=10
# Max FRESH runs of one normalized (brand, category, lang) per rolling day (429
# over this) — bounds one hot brand hammered from many IPs. A cache-served
# repeat is not a fresh run and never counts. 0 = kill-switch.
CHECKER_RATE_LIMIT_PER_BRAND_DAY=20
# Daily USD cap on summed checker cost (rolling 24h). At/over it a fresh run is
# refused with a friendly at-capacity 503; cached hits still return. Under
# DRY_RUN every cost is 0, so any positive cap never trips.
CHECKER_DAILY_USD_CAP=5.0

# --- Worker -----------------------------------------------------------------
WORKER_POLL_SECONDS=2
STALE_CLAIM_SECONDS=300

# --- Dev host ports (deploy/docker-compose.yml only) ------------------------
# Host-side published ports for `make dev` / the dev compose file. Change these
# if the defaults collide with something already running on your machine
# (container-internal ports and inter-container URLs are unaffected).
YANKI_DB_PORT=5432
YANKI_API_PORT=8141
YANKI_WEB_PORT=8140

# --- Prod host ports (deploy/docker-compose.prod.yml only) -------------------
# Loopback binds used ONLY by deploy.sh health checks / local debugging — the
# shared Caddy reaches the containers over the docker network aliases
# yanki-web / yanki-api, not these. Defaults dodge ports already in use on the
# beyondkaira VPS: 8140 belongs to another tenant, and 8141 is the dev stack's
# api default on the same box.
YANKI_PROD_WEB_PORT=8142
YANKI_PROD_API_PORT=8143
