# Yanki — import snippet for the SHARED pulse-prod Caddy.
#
# Yanki runs no Caddy of its own. Drop this file into the shared Caddy's import
# directory, then (never restart):
#     caddy validate --config /etc/caddy/Caddyfile
#     caddy reload   --config /etc/caddy/Caddyfile
#
# One origin, path-routed, so there is NO CORS:
#   /api/* + /healthz  -> FastAPI api on 127.0.0.1:8141
#   everything else    -> Next.js web on 127.0.0.1:8140
test.beyondkaira.com {
	# API + health check -> backend
	@api path /api/* /healthz
	handle @api {
		reverse_proxy 127.0.0.1:8141
	}

	# Everything else -> frontend
	handle {
		reverse_proxy 127.0.0.1:8140
	}
}
